# Copy this file to .env for local testing.
# On Render/Railway, set these as Environment Variables in the dashboard instead — do not upload .env there.

# A passphrase staff enter once in the board's "Email settings" panel.
# Without this, anyone with your backend URL could post or delete notes.
BOARD_KEY=choose-a-passphrase

# Get this from resend.com after verifying a sending domain (or use their
# test address onboarding@resend.dev while you're setting things up).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# Cron expression for when the digest sends, in the timezone below.
# Default: 11:00 PM every day.
DIGEST_CRON=0 23 * * *
TZ=America/New_York

# If true, the board is archived and cleared right after a successful send —
# fitting for a "nightly comms" board that starts fresh each day.
CLEAR_AFTER_SEND=true

PORT=3000
